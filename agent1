    function saveToDevice() { alert("Use 'Add to Home Screen' in browser menu."); }
    function playVoiceAlert() {
        const msg = new SpeechSynthesisUtterance("సిటిజెన్ డిజిటల్ సేవా మరియు మీసేవకు స్వాగతం.");
        msg.lang = 'te-IN'; window.speechSynthesis.speak(msg);
    }
	async function loadAlerts() {
    const container = document.getElementById('live-alerts');
    const modal = document.getElementById('specialModal');
    const popupContainer = document.getElementById('popup-image-container');

    try {
        const res = await fetch(sheetURL + '&cache=' + Date.now());
        const data = await res.text();
        const rows = data.split('\n').filter(r => r.trim() !== '').slice(1);
        
        // --- పాపప్ లాజిక్ ---
        // షీట్ లో మొదటి వరుసలోని 4వ కాలమ్ (D1) లో ఇమేజ్ ఉందో లేదో చూస్తుంది
        const firstRowCols = rows[0].split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/);
        const popupImgPath = firstRowCols[3] ? firstRowCols[3].trim() : "";

        if (popupImgPath && popupImgPath !== "") {
            popupContainer.innerHTML = `<img src="${popupImgPath}" alt="Special Greeting">`;
            modal.style.display = "block";
        }

        // --- పాత అలర్ట్స్ లాజిక్ ---
        container.innerHTML = '';
        rows.forEach(row => {
            const cols = row.split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/);
            if(cols.length >= 2) {
                const title = cols[0].replace(/"/g, '').trim();
                const link = cols[1].replace(/"/g, '').trim() || '#';
                const icon = cols[2] ? cols[2].replace(/"/g, '').trim() : 'fa-bell';
                container.innerHTML += `<a href="${link}" target="_blank" class="tab-btn"><i class="fas ${icon}"></i><span>${title}</span></a>`;
            }
        });
    } catch (e) { console.log("Data load error"); }
}

function closePopup() {
