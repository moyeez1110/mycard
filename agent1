<script>
    const sheetURL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vTHKl_lCWxq7k1pIQa85pTSoG_vO6QsyKWzzpfFSd6IOHtutocF2OgVZC1NOzBxWrRDMKLOxQrUbYBm/pub?output=csv';

    async function loadAlerts() {
        const container = document.getElementById('live-alerts');
        try {
            const res = await fetch(sheetURL + '&cache=' + Date.now());
            const data = await res.text();
            const rows = data.split('\n').filter(r => r.trim() !== '').slice(1);
            
            if (rows.length > 0) {
                container.innerHTML = '';
                rows.forEach(row => {
                    const cols = row.split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/);
                    if(cols.length >= 2) {
                        const title = cols[0].replace(/"/g, '').trim();
                        const link = cols[1].replace(/"/g, '').trim() || '#';
                        const icon = cols[2] ? cols[2].replace(/"/g, '').trim() : 'fa-bell';
                        
                        container.innerHTML += `
                            <a href="${link}" target="_blank" class="tab-btn">
                                <i class="fas ${icon}"></i>
                                <span>${title}</span>
                            </a>`;
                    }
                });
            }
        } catch (e) { console.log("Sheet load error, showing default tabs."); }
    }

    window.onload = loadAlerts;
    function toggleDarkMode() { document.body.classList.toggle('dark-mode'); }
